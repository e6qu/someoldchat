FROM golang:1.26 AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -trimpath -ldflags='-s -w' -o /out/ecs-ws-activator ./cmd/ecs-ws-activator

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=build /out/ecs-ws-activator /ecs-ws-activator
USER nonroot:nonroot
ENTRYPOINT ["/ecs-ws-activator"]
